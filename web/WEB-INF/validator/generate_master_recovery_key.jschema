{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generate Master Recovery Key Request",
  "type": "object",
  "properties": {
    "_func": {
      "type": "string",
      "const": "generate_master_recovery_key"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "The primary identifier for the admin account."
    }
  },
  "required": ["_func", "email"],
  "additionalProperties": false
}