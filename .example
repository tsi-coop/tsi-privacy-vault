# .env.example
# This file serves as a template for the .env file, which should
# contain actual sensitive configuration and MUST NOT be committed to Git.
#
# To use: Copy this file to .env and fill in the placeholder values.


# --- Database Configuration ---
# Recommended: A strong, random password.
POSTGRES_DB=tsi_privacy_vault
POSTGRES_USER=tsi_admin
POSTGRES_PASSWD=secure_dev_password

# --- Application Configuration---
# Environment
TSI_PRIVACY_VAULT_ENV=local
# Machine Name
TSI_PRIVACY_VAULT_NODE_ID=MUMBAI_DC_RACK04_SRV01
# 32 byte Master Key 
TSI_PRIVACY_VAULT_MASTER_KEY=6S6vH7pW2zN9kX4jR8mB3vC5xZ1aQ7yP0oL9iK2uJ4M
# JWT Secret 
TSI_PRIVACY_VAULT_JWT_SECRET=v7N2xQ9mR4kL1jP8bW5tZ3yX6sC0vA2d
# Software Version
TSI_PRIVACY_VAULT_SOFTWARE_VERSION=TSI PRIVACY VAULT v0.1
# Max upload size (in KB)
TSI_PRIVACY_VAULT_MAX_UPLOAD_KB=5120
# Search Index Secret Key
TSI_PRIVACY_VAULT_INDEX_SECRET=k9#z!L2@P$5m*N8^qV1&bX7*jR3+fW0_
# Data Export Path
 TSI_EXPORT_PATH=/var/lib/tsi/exports/
